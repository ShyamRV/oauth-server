
# Get yours at: https://asi1.ai/dashboard
ASI1_API_KEY=**********************************


# ── Google OAuth (YouTube Data API v3) ───────────────────────────
# 1. Go to https://console.cloud.google.com/
# 2. Create a project → Enable "YouTube Data API v3"
# 3. OAuth consent screen → External → Add scopes:
#      .../auth/youtube.upload
#      .../auth/youtube
#      .../auth/userinfo.email
# 4. Create OAuth 2.0 Client ID (Web application)
# 5. Add your redirect URI to Authorized redirect URIs
GOOGLE_CLIENT_ID=******************************
GOOGLE_CLIENT_SECRET=****************************
GOOGLE_REDIRECT_URI=***********************************

# ── LinkedIn OAuth (UGC Posts API) ────────────────────────────────
# 1. Go to https://www.linkedin.com/developers/apps
# 2. Create an app → Products: "Share on LinkedIn" + "Sign In with LinkedIn"
# 3. Auth tab → Add redirect URL
# 4. Copy Client ID and Client Secret
LINKEDIN_CLIENT_ID=**********************
LINKEDIN_CLIENT_SECRET=********************
LINKEDIN_REDIRECT_URI=******************************
# Default scopes for general LinkedIn apps. If your app is approved for more,
# you can extend this (e.g. add r_emailaddress).
LINKEDIN_SCOPES=*******************************

CHAT_APP_BASE_URL=https://asi1.ai   # or your chat URL, for browser redirect
# Optional strict session deep-link template (best when your chat UI supports stable chat IDs).
# Example: https://asi1.ai/chat/{chat_id}
CHAT_SESSION_URL_TEMPLATE=
# Generic default for public/multi-tenant use: do NOT auto-redirect browser.
# Set true only when CHAT_SESSION_URL_TEMPLATE is known-correct for your chat product.
AUTO_REDIRECT_SUCCESS=false
# Use unlisted for safer first-time visibility; switch to public if desired.
YOUTUBE_PRIVACY_STATUS=unlisted

# OAuth server on Render — same host as GOOGLE_REDIRECT_URI / LINKEDIN_REDIRECT_URI (oauth_server.py).
OAUTH_SERVER_URL=************************
SHARED_SECRET=***************************************
